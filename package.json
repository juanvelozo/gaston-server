{
  "name": "gaston",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter backend run generate",
    "db:migrate": "pnpm --filter backend run deploydb:dev",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "3.5.3",
    "turbo": "^2.3.0"
  }
}
